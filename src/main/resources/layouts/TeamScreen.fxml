<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0" style="-fx-background-color: #0c9aa6; -fx-padding: 10;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="sportsmanager.TeamScreenController">
    
    <VBox spacing="5.0">
        <Label text="Team Players" style="-fx-text-fill: #ffffff; -fx-font-size: 18px; -fx-font-weight: bold;" />
        <TableView fx:id="playersTable" prefHeight="250.0">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="infoColumn" prefWidth="40.0" minWidth="40.0" maxWidth="40.0" />
                <TableColumn fx:id="nameColumn" prefWidth="100.0" text="Name" />
                <TableColumn fx:id="statusColumn" prefWidth="120.0" text="Status" />
                <TableColumn fx:id="injuryColumn" prefWidth="120.0" text="Injury Status" />
                <TableColumn fx:id="returnInColumn" prefWidth="100.0" text="Return In" />
            </columns>
        </TableView>
    </VBox>
    
    <VBox spacing="5.0">
        <Label text="Tactics" style="-fx-text-fill: #ffffff; -fx-font-size: 18px; -fx-font-weight: bold;" />
        <TableView fx:id="tacticsTable" prefHeight="98.0">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="tacticNameColumn" text="Tactic Name" />
                <TableColumn fx:id="tacticSelectColumn" prefWidth="50.0" maxWidth="50.0" minWidth="50.0" />
            </columns>
        </TableView>
    </VBox>

    
    <HBox alignment="CENTER" spacing="30.0" style="-fx-padding: 20 0 10 0;">
        <VBox alignment="CENTER" spacing="5.0">
            <Label text="Played" style="-fx-text-fill: #ffffff; -fx-font-size: 18px; -fx-font-weight: bold;" />
            <Label fx:id="playedLabel" alignment="CENTER" prefHeight="50.0" prefWidth="60.0" style="-fx-background-color: transparent; -fx-border-color: black; -fx-border-radius: 10; -fx-border-width: 1; -fx-font-weight: bold;" />
        </VBox>
        <VBox alignment="CENTER" spacing="5.0">
            <Label text="Wins" style="-fx-text-fill: #0beb34; -fx-font-size: 18px; -fx-font-weight: bold;" />
            <Label fx:id="winsLabel" alignment="CENTER" prefHeight="50.0" prefWidth="60.0" style="-fx-background-color: transparent; -fx-border-color: black; -fx-border-radius: 10; -fx-border-width: 1; -fx-font-weight: bold;" />
        </VBox>
        <VBox alignment="CENTER" spacing="5.0">
            <Label text="Losses" style="-fx-text-fill: red; -fx-font-size: 18px; -fx-font-weight: bold;" />
            <Label fx:id="lossesLabel" alignment="CENTER" prefHeight="50.0" prefWidth="60.0" style="-fx-background-color: transparent; -fx-border-color: black; -fx-border-radius: 10; -fx-border-width: 1; -fx-font-weight: bold;" />
        </VBox>
        <VBox alignment="CENTER" spacing="5.0">
            <Label text="Draws" style="-fx-text-fill: #ffcd03; -fx-font-size: 18px; -fx-font-weight: bold;" />
            <Label fx:id="drawsLabel" alignment="CENTER" prefHeight="50.0" prefWidth="60.0" style="-fx-background-color: transparent; -fx-border-color: black; -fx-border-radius: 10; -fx-border-width: 1; -fx-font-weight: bold;" />
        </VBox>
    </HBox>
</VBox>
